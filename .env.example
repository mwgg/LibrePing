# Copy to .env and adjust. All values have sensible defaults in docker-compose.yml.

# --- Hub mesh ---
# Comma-separated libp2p multiaddrs of peer hubs to join on startup. Get a
# peer's address from its logs ("p2p mesh listening addrs=[...]"). Leave empty
# to run a standalone hub; once connected to a peer, hubs also discover each
# other via the DHT over time.
# Example: /ip4/203.0.113.10/tcp/4001/p2p/12D3KooW...
BOOTSTRAP_PEERS=
# Optional built-in/fallback bootstrap peers, merged with BOOTSTRAP_PEERS.
DEFAULT_BOOTSTRAP=
# Comma-separated hub URLs to bootstrap from automatically. On startup (and while
# isolated) the hub fetches each one's /api/v1/hubs + /api/v1/identity and dials
# the live, dialable peers listed there — a self-maintaining directory, so you
# don't hand-maintain BOOTSTRAP_PEERS. Dead hubs age out on their own. Discovered
# addresses are filtered to public ranges (unless HUB_ALLOW_PRIVATE_PEERS).
# Example: https://nl.lp.mw.gg,https://ca.lp.mw.gg,https://sg.lp.mw.gg
BOOTSTRAP_SEEDS=
# Publicly-reachable libp2p multiaddrs to ANNOUNCE to peers, when the
# auto-detected ones aren't dialable (NAT, containers). The libp2p port is TCP
# 4001 by default and must be reachable for others to dial you directly.
# Example: /ip4/203.0.113.10/tcp/4001
P2P_ANNOUNCE_ADDRS=
# Comma-separated /p2p relay multiaddrs for AutoRelay, to stay reachable behind
# NAT when direct dialing fails.
P2P_RELAYS=
# Enable local-network (mDNS) peer discovery — handy for a LAN of hubs or dev.
ENABLE_MDNS=false
# Allow directory reachability checks to reach private/LAN addresses (needed if
# you federate over a trusted private network; default false blocks SSRF).
HUB_ALLOW_PRIVATE_PEERS=false
# Per-IP rate limit (requests/min) on the write endpoints (create check/
# subscription/alert, probe register). 0 = sane default, negative = disabled.
WRITE_RATE_PER_MIN=

# --- Hub advertisement / directory ---
# Advertise this hub to the network so it appears in other hubs' /api/v1/hubs.
ADVERTISE=true
# This hub's public base URL. REQUIRED to advertise — peers fetch
# {PUBLIC_URL}/api/v1/identity to verify the hub before listing it.
PUBLIC_URL=
# Friendly name shown in directories / on the map.
HUB_NAME=
# Location shown on the map. Auto-detected from the public IP by default; set
# this "Country,City,lat,lon" to override, or HUB_GEOIP=false to disable the
# lookup. Self-declared either way — there is no proof-of-location.
HUB_LOCATION=
HUB_GEOIP=true

# --- Trust policy ---
# "open" (default): accept any validly-signed result, tagged by origin, and rely
#   on cross-probe corroboration. "allowlist": accept only TRUST_ALLOWLIST IDs.
TRUST_POLICY=open
# Comma-separated probe/hub node IDs (only used when TRUST_POLICY=allowlist).
TRUST_ALLOWLIST=

# --- Partial replication (storage role) ---
# Hubs don't all have to store the whole network's results. Pick a role:
#   shards  (default) — hold a capacity-weighted, rendezvous-assigned slice of
#                       the result shards (plus your own probes' + alert checks).
#   archive           — hold everything (a full mirror / durability backstop).
#   none              — store nothing but your own pins (a light, query-only hub).
# A solo hub or a mesh with <= 3 storage hubs holds everything regardless, so
# this is transparent until the network is large enough to spread.
HUB_STORAGE=shards
# Relative weight for shard placement (higher = hold a larger share). A big
# server might set 10; a NAS leaves it at 1. Ignored for archive/none.
HUB_STORAGE_CAPACITY=1

# --- Result storage tiers (TimescaleDB only) ---
# A hub stores its slice of the network's results (see HUB_STORAGE above), and
# disk is tiered so the further back a measurement is, the less detail is kept.
# Recent data is per-result (compressed); older data is rolled up to hourly then
# daily summaries; the oldest is dropped. Days; 0 = keep that tier forever.
# Compress raw results older than this (0 = no compression).
RESULT_COMPRESS_AFTER_DAYS=2
# Keep full per-result detail for this many days, then drop raw (hourly rollups
# already hold the summary).
RESULT_RETENTION_DAYS=7
# Keep hourly summaries this long, then drop (daily rollups carry on).
RESULT_HOURLY_RETENTION_DAYS=90
# Keep daily summaries this long.
RESULT_DAILY_RETENTION_DAYS=730

# --- Check distribution ---
# How many probes each hub tries to assign per check (corroboration target).
TARGET_REDUNDANCY=3
# Seed one HTTP check on first boot so a fresh network isn't empty (optional).
SEED_CHECK_TARGET=https://example.com

# --- Alerts ---
# Alert channels (ntfy, Discord, Slack, raw webhook) are all plain outbound HTTPS
# to an owner-supplied destination, so they need NO hub configuration.
# How often the alert engine evaluates rules it is responsible for.
ALERT_INTERVAL=30s
# How long a responsible hub may be silent before a peer takes over its alerts
# (failover window). Shorter = faster failover, more sensitive to flapping.
ALERT_HUB_TTL=3m
# Webhook alert destinations are validated as SSRF-safe (https-only, no
# loopback/private/metadata ranges, no redirects). Set true only to allow plain
# http to trusted internal endpoints.
ALERT_WEBHOOK_ALLOW_HTTP=false

# --- Local probe (full-hub compose) ---
# Location shown on the map. Auto-detected from the probe's public IP by default;
# set "Country,City,lat,lon" to override, or PROBE_GEOIP=false to disable the
# lookup. Self-declared either way — there is no proof-of-location.
PROBE_LOCATION=
PROBE_GEOIP=true
# Hard cap on how many checks this probe runs per minute (0 = unlimited). This
# caps the signed results your probe injects — a network-wide cost dial: each
# result costs disk + bandwidth on the hubs that store its shard (a few replicas,
# not every hub). The default suits a low-to-mid-tier VPS (checks are light,
# I/O-bound network probes); lower it to be a lighter network citizen, or raise
# it (hubs clamp at 600) on a beefier box.
MAX_CHECKS_PER_MINUTE=300
# Comma-separated check types this probe refuses (e.g. icmp,traceroute without
# the NET_RAW capability).
DISABLE_CHECKS=
# Block check targets that resolve to private/loopback/link-local/metadata
# ranges, so a public probe can't be made to scan its operator's LAN (SSRF).
# Default true. Set false, or allowlist specific CIDRs with PROBE_ALLOW_TARGETS,
# to deliberately monitor internal services.
PROBE_BLOCK_PRIVATE=true
# Comma-separated CIDRs allowed as targets even when PROBE_BLOCK_PRIVATE is on.
# Example: 10.0.0.0/8,192.168.1.0/24
PROBE_ALLOW_TARGETS=

# --- Probe-only node ---
# Running JUST a probe (no hub)? Don't use this file — use the much shorter
# .env.probe.example instead: `cp .env.probe.example .env`. The variables above
# are for a full hub; a probe needs only HUB_URL.
