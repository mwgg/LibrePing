# Probe-only node config. Copy to .env and you're done:
#
#   cp .env.probe.example .env
#   docker compose -f docker-compose.probe.yml up --build
#
# A probe needs nothing but a hub to send measurements to — and that's already
# filled in below, so it works out of the box. Everything else is optional.

# Hub(s) to contribute your measurements to. Comma-separated; the probe fails over
# between them and learns more from the mesh. Leave as-is to contribute to the
# public network, or point at your own hub.
HUB_URL=https://nl.lp.mw.gg

# --- Optional tweaks (uncomment to use) ---

# Pin your location instead of auto-detecting it from your public IP.
# PROBE_LOCATION="US,New York,40.71,-74.01"

# Disable the IP-based location lookup entirely.
# PROBE_GEOIP=false

# Cap how many checks/minute you run (your share of the load); lower on a small box.
# MAX_CHECKS_PER_MINUTE=300

# Refuse check types your host can't run (e.g. ICMP/traceroute without NET_RAW).
# DISABLE_CHECKS=icmp,traceroute
